    "diff": "^7.0.0",
    "semver": "^7.7.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.12.0",
    "@types/semver": "^7.5.8",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": ["windows-7", "ui", "components", "react", "svelte", "vue", "css"],
  "license": "MIT"
