{
  "name": "win7ui",
  "version": "0.1.0",
  "description": "Windows 7 UI component library - add components to your project",
  "type": "module",
  "bin": {
    "win7ui": "./dist/index.js"
  },
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "@clack/prompts": "^0.9.1",
    "fs-extra": "^11.3.0",
