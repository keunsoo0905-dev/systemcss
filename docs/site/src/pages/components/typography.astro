---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Typography">
  <h1 class="header header-document">Typography</h1>
  <p class="instruction">Windows 7 스타일 텍스트 컴포넌트. Instruction, InstructionPrimary, HeaderDocument, HeaderGroup을 제공합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add typography</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <h1 class="header header-document">HeaderDocument</h1>
    <h2 class="header header-group">HeaderGroup</h2>
    <p class="instruction">Instruction - standard body text style.</p>
    <p class="instruction instruction-primary">InstructionPrimary - emphasized instruction text.</p>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="ty-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="ty-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="ty-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="ty-react" class="active">
      <pre><code><span class="kw">import</span> &#123;
  <span class="ty">Instruction</span>,
  <span class="ty">InstructionPrimary</span>,
  <span class="ty">HeaderDocument</span>,
  <span class="ty">HeaderGroup</span>,
&#125; <span class="kw">from</span> <span class="str">"./components/win7ui/typography"</span>;

&lt;<span class="ty">HeaderDocument</span>&gt;Page Title&lt;/<span class="ty">HeaderDocument</span>&gt;
&lt;<span class="ty">HeaderGroup</span>&gt;Section Title&lt;/<span class="ty">HeaderGroup</span>&gt;
&lt;<span class="ty">Instruction</span>&gt;Body text&lt;/<span class="ty">Instruction</span>&gt;
&lt;<span class="ty">InstructionPrimary</span>&gt;Emphasized text&lt;/<span class="ty">InstructionPrimary</span>&gt;

<span class="cm">// Custom element</span>
&lt;<span class="ty">HeaderGroup</span> <span class="fn">as</span>=<span class="str">"h3"</span>&gt;H3 heading&lt;/<span class="ty">HeaderGroup</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="ty-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123;
    <span class="ty">HeaderDocument</span>, <span class="ty">HeaderGroup</span>,
    <span class="ty">Instruction</span>, <span class="ty">InstructionPrimary</span>
  &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/typography"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">HeaderDocument</span>&gt;Page Title&lt;/<span class="ty">HeaderDocument</span>&gt;
&lt;<span class="ty">HeaderGroup</span>&gt;Section Title&lt;/<span class="ty">HeaderGroup</span>&gt;
&lt;<span class="ty">Instruction</span>&gt;Body text&lt;/<span class="ty">Instruction</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="ty-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123;
  <span class="ty">HeaderDocument</span>, <span class="ty">HeaderGroup</span>,
  <span class="ty">Instruction</span>, <span class="ty">InstructionPrimary</span>
&#125; <span class="kw">from</span> <span class="str">"./components/win7ui/typography"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">HeaderDocument</span>&gt;Page Title&lt;/<span class="ty">HeaderDocument</span>&gt;
  &lt;<span class="ty">HeaderGroup</span>&gt;Section Title&lt;/<span class="ty">HeaderGroup</span>&gt;
  &lt;<span class="ty">Instruction</span>&gt;Body text&lt;/<span class="ty">Instruction</span>&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Components</h2>
  <table>
    <thead><tr><th>Component</th><th>Default Tag</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>Instruction</td><td><code>&lt;p&gt;</code></td><td>Standard body text (9pt Segoe UI)</td></tr>
      <tr><td>InstructionPrimary</td><td><code>&lt;p&gt;</code></td><td>Emphasized instruction (12pt, blue)</td></tr>
      <tr><td>HeaderDocument</td><td><code>&lt;h1&gt;</code></td><td>Document title (17pt Calibri)</td></tr>
      <tr><td>HeaderGroup</td><td><code>&lt;h2&gt;</code></td><td>Section heading (11pt, blue)</td></tr>
    </tbody>
  </table>

  <h2 class="header header-group">Props</h2>
  <p class="instruction">All typography components share the same props:</p>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>as</td><td><code>React.ElementType</code></td><td>varies</td><td>Override the rendered HTML element</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
</BaseLayout>
