---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Balloon">
  <h1 class="header header-document">Balloon</h1>
  <p class="instruction">Windows 7 스타일 말풍선 툴팁. 위치(top/bottom)와 화살표 정렬(left/right)을 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add balloon</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <div role="tooltip" style="display: inline-block; border: 1px solid #333; background: #ffffe1; padding: 8px 12px; border-radius: 4px; font-size: 12px; box-shadow: 2px 2px 4px rgba(0,0,0,0.2); max-width: 250px;">
      <p style="margin: 0 0 4px; font-weight: 600;">Notification</p>
      <p style="margin: 0;">This is a balloon tooltip message from Windows 7.</p>
    </div>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="bl-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="bl-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="bl-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="bl-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">Balloon</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/balloon"</span>;

&lt;<span class="ty">Balloon</span> <span class="fn">position</span>=<span class="str">"bottom"</span> <span class="fn">arrowAlign</span>=<span class="str">"left"</span>&gt;
  &lt;p&gt;Tooltip content&lt;/p&gt;
&lt;/<span class="ty">Balloon</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="bl-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">Balloon</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/balloon"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">Balloon</span> <span class="fn">position</span>=<span class="str">"bottom"</span>&gt;Tooltip&lt;/<span class="ty">Balloon</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="bl-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">Balloon</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/balloon"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">Balloon</span> <span class="fn">position</span>=<span class="str">"bottom"</span>&gt;Tooltip&lt;/<span class="ty">Balloon</span>&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>position</td><td><code>"top" | "bottom"</code></td><td><code>"bottom"</code></td><td>Arrow direction (bottom = arrow points up)</td></tr>
      <tr><td>arrowAlign</td><td><code>"left" | "right"</code></td><td><code>"left"</code></td><td>Arrow horizontal alignment</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
  <p class="instruction">Extends <code>React.HTMLAttributes&lt;HTMLDivElement&gt;</code>.</p>
</BaseLayout>
