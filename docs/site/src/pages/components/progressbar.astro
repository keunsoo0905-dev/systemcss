---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="ProgressBar">
  <h1 class="header header-document">ProgressBar</h1>
  <p class="instruction">Windows 7 스타일 프로그래스 바. normal, paused, error 상태와 marquee 모드를 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add progressbar</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <div style="display: flex; flex-direction: column; gap: 12px; max-width: 300px;">
      <div>
        <p class="instruction" style="margin-bottom: 4px;">Normal (70%)</p>
        <div role="progressbar" aria-valuenow="70" aria-valuemin="0" aria-valuemax="100">
          <div style="width: 70%;"></div>
        </div>
      </div>
      <div>
        <p class="instruction" style="margin-bottom: 4px;">Paused (50%)</p>
        <div role="progressbar" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" class="paused">
          <div style="width: 50%;"></div>
        </div>
      </div>
      <div>
        <p class="instruction" style="margin-bottom: 4px;">Error (30%)</p>
        <div role="progressbar" aria-valuenow="30" aria-valuemin="0" aria-valuemax="100" class="error">
          <div style="width: 30%;"></div>
        </div>
      </div>
    </div>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="pb-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="pb-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="pb-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="pb-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">ProgressBar</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/progressbar"</span>;

&lt;<span class="ty">ProgressBar</span> <span class="fn">value</span>=&#123;<span class="num">70</span>&#125; /&gt;
&lt;<span class="ty">ProgressBar</span> <span class="fn">value</span>=&#123;<span class="num">50</span>&#125; <span class="fn">state</span>=<span class="str">"paused"</span> /&gt;
&lt;<span class="ty">ProgressBar</span> <span class="fn">value</span>=&#123;<span class="num">30</span>&#125; <span class="fn">state</span>=<span class="str">"error"</span> /&gt;
&lt;<span class="ty">ProgressBar</span> <span class="fn">marquee</span> /&gt;  <span class="cm">// indeterminate</span></code></pre>
    </div>
    <div role="tabpanel" id="pb-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">ProgressBar</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/progressbar"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">ProgressBar</span> <span class="fn">value</span>=&#123;<span class="num">70</span>&#125; /&gt;
&lt;<span class="ty">ProgressBar</span> <span class="fn">value</span>=&#123;<span class="num">50</span>&#125; <span class="fn">state</span>=<span class="str">"paused"</span> /&gt;
&lt;<span class="ty">ProgressBar</span> <span class="fn">marquee</span> /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="pb-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">ProgressBar</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/progressbar"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">ProgressBar</span> <span class="fn">:value</span>=<span class="str">"70"</span> /&gt;
  &lt;<span class="ty">ProgressBar</span> <span class="fn">:value</span>=<span class="str">"50"</span> <span class="fn">state</span>=<span class="str">"paused"</span> /&gt;
  &lt;<span class="ty">ProgressBar</span> <span class="fn">marquee</span> /&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>value</td><td><code>number</code></td><td><code>0</code></td><td>Current progress value</td></tr>
      <tr><td>min</td><td><code>number</code></td><td><code>0</code></td><td>Minimum value</td></tr>
      <tr><td>max</td><td><code>number</code></td><td><code>100</code></td><td>Maximum value</td></tr>
      <tr><td>state</td><td><code>"normal" | "paused" | "error"</code></td><td><code>"normal"</code></td><td>Visual state</td></tr>
      <tr><td>animate</td><td><code>boolean</code></td><td><code>false</code></td><td>Enable animation</td></tr>
      <tr><td>marquee</td><td><code>boolean</code></td><td><code>false</code></td><td>Indeterminate mode</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
</BaseLayout>
