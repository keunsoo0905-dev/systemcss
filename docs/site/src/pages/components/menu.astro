---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Menu">
  <h1 class="header header-document">Menu</h1>
  <p class="instruction">Windows 7 스타일 컨텍스트 메뉴. 서브메뉴, 구분선, 비활성 항목을 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add menu</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <ul role="menu" style="display: inline-block; border: 1px solid #999; background: #f0f0f0; padding: 2px; min-width: 160px; box-shadow: 2px 2px 4px rgba(0,0,0,0.2);">
      <li role="menuitem" style="padding: 4px 20px; cursor: pointer;">Open</li>
      <li role="menuitem" style="padding: 4px 20px; cursor: pointer;">Save</li>
      <li style="border-top: 1px solid #d5d5d5; margin: 2px 0;"></li>
      <li role="menuitem" style="padding: 4px 20px; color: #999;">Disabled</li>
      <li role="menuitem" style="padding: 4px 20px; cursor: pointer;">Exit</li>
    </ul>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="mn-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="mn-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="mn-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="mn-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">Menu</span>, <span class="ty">MenuItem</span>, <span class="ty">MenuSeparator</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/menu"</span>;

&lt;<span class="ty">Menu</span>&gt;
  &lt;<span class="ty">MenuItem</span> <span class="fn">onSelect</span>=&#123;() =&gt; <span class="fn">handleOpen</span>()&#125;&gt;Open&lt;/<span class="ty">MenuItem</span>&gt;
  &lt;<span class="ty">MenuItem</span> <span class="fn">onSelect</span>=&#123;() =&gt; <span class="fn">handleSave</span>()&#125;&gt;Save&lt;/<span class="ty">MenuItem</span>&gt;
  &lt;<span class="ty">MenuSeparator</span> /&gt;
  &lt;<span class="ty">MenuItem</span> <span class="fn">disabled</span>&gt;Disabled&lt;/<span class="ty">MenuItem</span>&gt;
  &lt;<span class="ty">MenuItem</span>&gt;Exit&lt;/<span class="ty">MenuItem</span>&gt;
&lt;/<span class="ty">Menu</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="mn-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">Menu</span>, <span class="ty">MenuItem</span>, <span class="ty">MenuSeparator</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/menu"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">Menu</span>&gt;
  &lt;<span class="ty">MenuItem</span>&gt;Open&lt;/<span class="ty">MenuItem</span>&gt;
  &lt;<span class="ty">MenuSeparator</span> /&gt;
  &lt;<span class="ty">MenuItem</span> <span class="fn">disabled</span>&gt;Disabled&lt;/<span class="ty">MenuItem</span>&gt;
&lt;/<span class="ty">Menu</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="mn-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">Menu</span>, <span class="ty">MenuItem</span>, <span class="ty">MenuSeparator</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/menu"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">Menu</span>&gt;
    &lt;<span class="ty">MenuItem</span>&gt;Open&lt;/<span class="ty">MenuItem</span>&gt;
    &lt;<span class="ty">MenuSeparator</span> /&gt;
    &lt;<span class="ty">MenuItem</span> <span class="fn">disabled</span>&gt;Disabled&lt;/<span class="ty">MenuItem</span>&gt;
  &lt;/<span class="ty">Menu</span>&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <h3>Menu</h3>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
  <h3>MenuItem</h3>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>disabled</td><td><code>boolean</code></td><td><code>false</code></td><td>Disable the menu item</td></tr>
      <tr><td>onSelect</td><td><code>() =&gt; void</code></td><td>-</td><td>Click/select callback</td></tr>
      <tr><td>submenu</td><td><code>ReactNode</code></td><td>-</td><td>Submenu content</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
</BaseLayout>
