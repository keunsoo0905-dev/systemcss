---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Spinner">
  <h1 class="header header-document">Spinner</h1>
  <p class="instruction">Windows 7 스타일 로딩 스피너. 정적/애니메이션 모드와 3가지 크기를 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add spinner</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <div style="display: flex; gap: 16px; align-items: center;">
      <div role="status" style="width: 16px; height: 16px; border: 2px solid #0078d7; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
      <div role="status" style="width: 24px; height: 24px; border: 2px solid #0078d7; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
      <div role="status" style="width: 32px; height: 32px; border: 3px solid #0078d7; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
    </div>
    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="sp-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="sp-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="sp-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="sp-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">Spinner</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/spinner"</span>;

&lt;<span class="ty">Spinner</span> /&gt;                           <span class="cm">// static</span>
&lt;<span class="ty">Spinner</span> <span class="fn">animate</span> /&gt;                    <span class="cm">// animated</span>
&lt;<span class="ty">Spinner</span> <span class="fn">animate</span> <span class="fn">size</span>=<span class="str">"large"</span> /&gt;       <span class="cm">// large animated</span></code></pre>
    </div>
    <div role="tabpanel" id="sp-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">Spinner</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/spinner"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">Spinner</span> <span class="fn">animate</span> <span class="fn">size</span>=<span class="str">"large"</span> /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="sp-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">Spinner</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/spinner"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">Spinner</span> <span class="fn">animate</span> <span class="fn">size</span>=<span class="str">"large"</span> /&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>animate</td><td><code>boolean</code></td><td><code>false</code></td><td>Enable spinning animation</td></tr>
      <tr><td>size</td><td><code>"small" | "default" | "large"</code></td><td><code>"default"</code></td><td>Spinner size</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
</BaseLayout>
