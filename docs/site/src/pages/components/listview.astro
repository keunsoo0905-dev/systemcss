---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="ListView">
  <h1 class="header header-document">ListView</h1>
  <p class="instruction">Windows 7 스타일 테이블 기반 데이터 목록. 정렬 및 행 선택을 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add listview</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <table style="max-width: 400px;">
      <thead><tr><th>Name</th><th>Size</th><th>Type</th></tr></thead>
      <tbody>
        <tr><td>document.txt</td><td>12 KB</td><td>Text</td></tr>
        <tr><td>image.png</td><td>2.4 MB</td><td>Image</td></tr>
        <tr><td>app.exe</td><td>8.1 MB</td><td>Application</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="lv-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="lv-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="lv-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="lv-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">ListView</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/listview"</span>;

&lt;<span class="ty">ListView</span>
  <span class="fn">columns</span>=&#123;[
    &#123; <span class="fn">key</span>: <span class="str">"name"</span>, <span class="fn">label</span>: <span class="str">"Name"</span> &#125;,
    &#123; <span class="fn">key</span>: <span class="str">"size"</span>, <span class="fn">label</span>: <span class="str">"Size"</span>, <span class="fn">width</span>: <span class="num">100</span> &#125;,
    &#123; <span class="fn">key</span>: <span class="str">"type"</span>, <span class="fn">label</span>: <span class="str">"Type"</span> &#125;,
  ]&#125;
  <span class="fn">data</span>=&#123;[
    &#123; <span class="fn">name</span>: <span class="str">"document.txt"</span>, <span class="fn">size</span>: <span class="str">"12 KB"</span>, <span class="fn">type</span>: <span class="str">"Text"</span> &#125;,
    &#123; <span class="fn">name</span>: <span class="str">"image.png"</span>, <span class="fn">size</span>: <span class="str">"2.4 MB"</span>, <span class="fn">type</span>: <span class="str">"Image"</span> &#125;,
  ]&#125;
  <span class="fn">onSort</span>=&#123;(<span class="fn">key</span>, <span class="fn">dir</span>) =&gt; <span class="fn">console</span>.<span class="fn">log</span>(<span class="fn">key</span>, <span class="fn">dir</span>)&#125;
/&gt;</code></pre>
    </div>
    <div role="tabpanel" id="lv-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">ListView</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/listview"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">ListView</span> <span class="fn">columns</span>=&#123;columns&#125; <span class="fn">data</span>=&#123;data&#125; /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="lv-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">ListView</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/listview"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">ListView</span> <span class="fn">:columns</span>=<span class="str">"columns"</span> <span class="fn">:data</span>=<span class="str">"data"</span> /&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>columns</td><td><code>ListViewColumn[]</code></td><td>required</td><td>Array of &#123; key, label, width? &#125;</td></tr>
      <tr><td>data</td><td><code>Record&lt;string, ReactNode&gt;[]</code></td><td>required</td><td>Row data array</td></tr>
      <tr><td>sortKey</td><td><code>string</code></td><td>-</td><td>Current sort column key</td></tr>
      <tr><td>sortDirection</td><td><code>"asc" | "desc"</code></td><td>-</td><td>Current sort direction</td></tr>
      <tr><td>onSort</td><td><code>(key, dir) =&gt; void</code></td><td>-</td><td>Sort change callback</td></tr>
      <tr><td>onRowSelect</td><td><code>(index, row) =&gt; void</code></td><td>-</td><td>Row selection callback</td></tr>
      <tr><td>hasShadow</td><td><code>boolean</code></td><td><code>false</code></td><td>Show shadow effect</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
</BaseLayout>
