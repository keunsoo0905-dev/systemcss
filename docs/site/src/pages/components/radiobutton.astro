---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="RadioButton">
  <h1 class="header header-document">RadioButton</h1>
  <p class="instruction">Windows 7 스타일 라디오 버튼. 같은 <code>name</code>으로 그룹핑합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add radiobutton</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <div style="display: flex; flex-direction: column; gap: 6px;">
      <span><input type="radio" id="r1" name="demo" checked /><label for="r1"> Option A</label></span>
      <span><input type="radio" id="r2" name="demo" /><label for="r2"> Option B</label></span>
      <span><input type="radio" id="r3" name="demo" disabled /><label for="r3"> Disabled</label></span>
    </div>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="rb-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="rb-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="rb-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="rb-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">RadioButton</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/radiobutton"</span>;

&lt;<span class="ty">RadioButton</span> <span class="fn">name</span>=<span class="str">"choice"</span> <span class="fn">label</span>=<span class="str">"Option A"</span> <span class="fn">defaultChecked</span> /&gt;
&lt;<span class="ty">RadioButton</span> <span class="fn">name</span>=<span class="str">"choice"</span> <span class="fn">label</span>=<span class="str">"Option B"</span> /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="rb-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">RadioButton</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/radiobutton"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">RadioButton</span> <span class="fn">name</span>=<span class="str">"choice"</span> <span class="fn">label</span>=<span class="str">"Option A"</span> /&gt;
&lt;<span class="ty">RadioButton</span> <span class="fn">name</span>=<span class="str">"choice"</span> <span class="fn">label</span>=<span class="str">"Option B"</span> /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="rb-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">RadioButton</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/radiobutton"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">RadioButton</span> <span class="fn">name</span>=<span class="str">"choice"</span> <span class="fn">label</span>=<span class="str">"Option A"</span> /&gt;
  &lt;<span class="ty">RadioButton</span> <span class="fn">name</span>=<span class="str">"choice"</span> <span class="fn">label</span>=<span class="str">"Option B"</span> /&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>label</td><td><code>string</code></td><td>required</td><td>Radio button label text</td></tr>
      <tr><td>name</td><td><code>string</code></td><td>-</td><td>Radio group name</td></tr>
      <tr><td>disabled</td><td><code>boolean</code></td><td><code>false</code></td><td>Disable the radio button</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
  <p class="instruction">Extends <code>React.InputHTMLAttributes</code> (excluding <code>type</code>).</p>
</BaseLayout>
