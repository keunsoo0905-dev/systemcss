---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="TreeView">
  <h1 class="header header-document">TreeView</h1>
  <p class="instruction">Windows 7 스타일 트리뷰. container, collapse-button, connector 변형을 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add treeview</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <ul class="tree-view" style="max-width: 250px;">
      <li>Desktop
        <ul>
          <li>Documents
            <ul>
              <li>report.docx</li>
              <li>notes.txt</li>
            </ul>
          </li>
          <li>Pictures
            <ul>
              <li>photo.jpg</li>
            </ul>
          </li>
        </ul>
      </li>
    </ul>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="tv-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="tv-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="tv-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="tv-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">TreeView</span>, <span class="ty">TreeItem</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/treeview"</span>;

&lt;<span class="ty">TreeView</span> <span class="fn">variant</span>=<span class="str">"collapse-button"</span>&gt;
  &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"Desktop"</span> <span class="fn">open</span>&gt;
    &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"Documents"</span>&gt;
      &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"report.docx"</span> /&gt;
    &lt;/<span class="ty">TreeItem</span>&gt;
  &lt;/<span class="ty">TreeItem</span>&gt;
&lt;/<span class="ty">TreeView</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="tv-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">TreeView</span>, <span class="ty">TreeItem</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/treeview"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">TreeView</span> <span class="fn">variant</span>=<span class="str">"collapse-button"</span>&gt;
  &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"Desktop"</span> <span class="fn">open</span>&gt;
    &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"report.docx"</span> /&gt;
  &lt;/<span class="ty">TreeItem</span>&gt;
&lt;/<span class="ty">TreeView</span>&gt;</code></pre>
    </div>
    <div role="tabpanel" id="tv-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">TreeView</span>, <span class="ty">TreeItem</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/treeview"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">TreeView</span> <span class="fn">variant</span>=<span class="str">"collapse-button"</span>&gt;
    &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"Desktop"</span> <span class="fn">open</span>&gt;
      &lt;<span class="ty">TreeItem</span> <span class="fn">label</span>=<span class="str">"report.docx"</span> /&gt;
    &lt;/<span class="ty">TreeItem</span>&gt;
  &lt;/<span class="ty">TreeView</span>&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <h3>TreeView</h3>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>variant</td><td><code>"default" | "container" | "collapse-button" | "connector"</code></td><td><code>"default"</code></td><td>Tree view visual style</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
  <h3>TreeItem</h3>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>label</td><td><code>string</code></td><td>required</td><td>Item label text</td></tr>
      <tr><td>open</td><td><code>boolean</code></td><td><code>false</code></td><td>Initially expanded (collapse-button variant)</td></tr>
    </tbody>
  </table>
</BaseLayout>
