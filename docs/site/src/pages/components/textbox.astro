---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="TextBox">
  <h1 class="header header-document">TextBox</h1>
  <p class="instruction">Windows 7 스타일 텍스트 입력 필드. <code>multiline</code> 모드로 textarea도 지원합니다.</p>

  <h2 class="header header-group">Installation</h2>
  <pre><code>npx win7ui add textbox</code></pre>

  <h2 class="header header-group">Demo</h2>
  <div class="demo-box">
    <div style="display: flex; flex-direction: column; gap: 8px; max-width: 300px;">
      <input type="text" placeholder="Single line input" />
      <textarea rows="3" placeholder="Multiline textarea"></textarea>
    </div>
  </div>

  <h2 class="header header-group">Usage</h2>
  <div class="code-tabs">
    <menu role="tablist">
      <li role="tab" aria-selected="true" aria-controls="tb-react">React</li>
      <li role="tab" aria-selected="false" aria-controls="tb-svelte">Svelte</li>
      <li role="tab" aria-selected="false" aria-controls="tb-vue">Vue</li>
    </menu>
    <div role="tabpanel" id="tb-react" class="active">
      <pre><code><span class="kw">import</span> &#123; <span class="ty">TextBox</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/textbox"</span>;

&lt;<span class="ty">TextBox</span> <span class="fn">placeholder</span>=<span class="str">"Enter text"</span> /&gt;
&lt;<span class="ty">TextBox</span> <span class="fn">multiline</span> <span class="fn">rows</span>=&#123;<span class="num">3</span>&#125; /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="tb-svelte">
      <pre><code>&lt;<span class="kw">script</span>&gt;
  <span class="kw">import</span> &#123; <span class="ty">TextBox</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/textbox"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="ty">TextBox</span> <span class="fn">placeholder</span>=<span class="str">"Enter text"</span> /&gt;
&lt;<span class="ty">TextBox</span> <span class="fn">multiline</span> <span class="fn">rows</span>=&#123;<span class="num">3</span>&#125; /&gt;</code></pre>
    </div>
    <div role="tabpanel" id="tb-vue">
      <pre><code>&lt;<span class="kw">script</span> <span class="fn">setup</span>&gt;
<span class="kw">import</span> &#123; <span class="ty">TextBox</span> &#125; <span class="kw">from</span> <span class="str">"./components/win7ui/textbox"</span>;
&lt;/<span class="kw">script</span>&gt;

&lt;<span class="kw">template</span>&gt;
  &lt;<span class="ty">TextBox</span> <span class="fn">placeholder</span>=<span class="str">"Enter text"</span> /&gt;
  &lt;<span class="ty">TextBox</span> <span class="fn">multiline</span> <span class="fn">:rows</span>=<span class="str">"3"</span> /&gt;
&lt;/<span class="kw">template</span>&gt;</code></pre>
    </div>
  </div>

  <h2 class="header header-group">Props</h2>
  <table>
    <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td>multiline</td><td><code>boolean</code></td><td><code>false</code></td><td>Render as textarea</td></tr>
      <tr><td>placeholder</td><td><code>string</code></td><td>-</td><td>Placeholder text</td></tr>
      <tr><td>className</td><td><code>string</code></td><td>-</td><td>Additional CSS class</td></tr>
    </tbody>
  </table>
  <p class="instruction">
    When <code>multiline=false</code>: extends <code>React.InputHTMLAttributes</code>.<br/>
    When <code>multiline=true</code>: extends <code>React.TextareaHTMLAttributes</code>.
  </p>
</BaseLayout>
